# SQLite database file path (default: ./support_crm.db)
DATABASE_URL=sqlite:///./support_crm.db

# Comma-separated origins for CORS (dev + production frontend URL)
CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# Server port (Railway sets PORT automatically)
PORT=8000

# Optional: frontend API base URL when not using Vite proxy
# VITE_API_URL=
